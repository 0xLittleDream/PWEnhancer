{
  "manifest_version": 3,
  "name": "PW Enhancer",
  "version": "3.0.0",
  "description": "The ultimate extension to supercharge your Physics Wallah experience.",
  "host_permissions": [
    "<all_urls>"
  ],
  "permissions": [
    "storage",
    "activeTab",
    "downloads",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PW Enhancer Settings",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content/main.js", "content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [ "<all_urls>" ],
      "resources": [ 
        "content/cloneMediaSources-for-page-world.js", 
        "content/SilenceDetectorProcessor.js", 
        "content/VolumeFilterProcessor.js", 
        "chunks/*.js" 
      ]
    }
  ]
}
